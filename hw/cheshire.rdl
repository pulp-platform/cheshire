`ifndef CHESHIRE_RDL
`define CHESHIRE_RDL

`include "regs.rdl"

// User-defined property for executable memory regions (used by ldh format)
property executable {
  component = mem;
  type = boolean;
};

// Stub addrmap for peripherals whose full RDL is not yet available.
// A single external status register is used to satisfy SystemRDL constraints.
addrmap periph_stub_t {
    external reg { field {} status[31:0] = 0; } status @0x0;
};

addrmap cheshire {
    desc = "Cheshire SoC system address map";

    ////////////////////
    // Memory regions //
    ////////////////////

    // External ROM at address 0 (loaded via debug/JTAG); 48 KiB, read+exec
    external mem {
        mementries = 12288; memwidth = 32;
        sw = r; executable = true;
    } extrom @0x0000_0000;

    // Internal boot ROM; 16 KiB, read+exec
    external mem {
        mementries = 4096; memwidth = 32;
        sw = r; executable = true;
    } bootrom @0x0200_0000;

    // Scratchpad memory (SPM / LLC); 64 KiB minimum, read+write+exec
    external mem {
        mementries = 16384; memwidth = 32;
        sw = rw; executable = true;
    } spm @0x1000_0000;

    // DRAM; 8 MiB minimum (Linux requirement), read+write+exec
    external mem {
        mementries = 2097152; memwidth = 32;
        sw = rw; executable = true;
    } dram @0x8000_0000;

    /////////////////
    // Peripherals //
    /////////////////

    // iDMA engine
    periph_stub_t dma @0x0100_0000;

    // CLINT
    periph_stub_t clint @0x0204_0000;

    // AXI-RT traffic regulator
    periph_stub_t axirt @0x020C_0000;

    // PLIC
    periph_stub_t plic @0x0400_0000;

    // CLIC
    periph_stub_t clic @0x0800_0000;

    // Cheshire SoC register file
    cheshire_regs regs @0x0300_0000;

    // LLC / SPM register interface
    periph_stub_t llc @0x0300_1000;

    // UART
    periph_stub_t uart @0x0300_2000;

    // I2C
    periph_stub_t i2c @0x0300_3000;

    // SPI host
    periph_stub_t spih @0x0300_4000;

    // GPIO
    periph_stub_t gpio @0x0300_5000;

    // Serial link
    periph_stub_t slink @0x0300_6000;

    // AXI VGA
    periph_stub_t vga @0x0300_7000;

    // USB
    periph_stub_t usb @0x0300_8000;

    // Bus error unit
    periph_stub_t bus_err @0x0300_9000;
};

`endif // CHESHIRE_RDL
