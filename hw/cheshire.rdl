`ifndef __CHESHIRE_RDL__
`define __CHESHIRE_RDL__

`include "cheshire_internal.rdl"

// Cheshire RDL wrapper. Not necessary for SoC integration since it would
// create an address map with empty addresses.
// uSually the external DRAM should be set at the top level (chip-dependent)
addrmap cheshire #(
    longint unsigned SlinkNumLanes = 4,
    longint unsigned DramStart = 64'h8000_0000
) {
    desc = "Cheshire SoC external memory regions";

    // Cheshire internal regsters
    cheshire_internal #(.SlinkNumLanes(SlinkNumLanes)) cheshire_internal @0x0000_0000;

    // DRAM; 8 MiB minimum (Linux requirement), read+write+exec
    // Reuse the executable property already defined in cheshire_internal.rdl
    external mem {
        mementries = 2097152; memwidth = 32;
        sw = rw; executable = true;
    } dram @DramStart;
};

`endif // __CHESHIRE_RDL__
