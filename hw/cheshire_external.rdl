`ifndef __CHESHIRE_EXTERNAL_RDL__
`define __CHESHIRE_EXTERNAL_RDL__

// User-defined property for executable memory regions (used by ldh format).
// Duplicated from cheshire.rdl to keep this file standalone.
property executable {
  component = mem;
  type = boolean;
};

// External (off-chip) memory regions of the Cheshire SoC.
// Kept separate from cheshire.rdl so that top-level integrators can instantiate
// the dense peripheral addrmap (cheshire) and the external memory region
// (cheshire_external) independently, avoiding a 1.6 GiB hole in the top-level
// address map footprint.
addrmap cheshire_external {
    desc = "Cheshire SoC external memory regions";

    // DRAM; 8 MiB minimum (Linux requirement), read+write+exec
    external mem {
        mementries = 2097152; memwidth = 32;
        sw = rw; executable = true;
    } dram @0x8000_0000;
};

`endif // __CHESHIRE_EXTERNAL_RDL__
